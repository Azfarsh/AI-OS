# OpenRouter — sign up free: https://openrouter.ai/keys
OPENROUTER_API_KEY=sk-or-v1-your-key-here
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# Free-tier testing (uses configs/free-test.yaml — $0 models on OpenRouter)
AIS_USE_FREE_MODELS=true
AIS_DEFAULT_MODEL=openrouter/free

# Set false to use paid models from configs/default.yaml
# AIS_USE_FREE_MODELS=false
# AIS_DEFAULT_MODEL=anthropic/claude-3.5-sonnet

OLLAMA_BASE_URL=http://localhost:11434/v1
OLLAMA_API_KEY=ollama

AIS_MEMORY_DIR=./memory/store
AIS_CHROMA_PATH=./memory/chroma
AIS_SESSIONS_DIR=./sessions
AIS_WORKSPACE=.

AIS_LOG_LEVEL=INFO
AIS_LOG_DIR=./logs

# Phase 2+ (not needed for free terminal testing)
# ELEVENLABS_API_KEY=
# GITHUB_TOKEN=
# SLACK_BOT_TOKEN=
