# OpenRouter (required for chat)
OPENROUTER_API_KEY=sk-or-v1-your-key-here
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# Default model (OpenRouter model id)
AIS_DEFAULT_MODEL=anthropic/claude-3.5-sonnet

# Local Ollama (optional fallback)
OLLAMA_BASE_URL=http://localhost:11434/v1
OLLAMA_API_KEY=ollama

# Memory
AIS_MEMORY_DIR=./memory/store
AIS_CHROMA_PATH=./memory/chroma
AIS_SESSIONS_DIR=./sessions

# Workspace root (AIS-OS kit files: context/, connections.md, etc.)
AIS_WORKSPACE=.

# Logging
AIS_LOG_LEVEL=INFO
AIS_LOG_DIR=./logs

# Phase 2 — Voice (optional)
# ELEVENLABS_API_KEY=
# WHISPER_MODEL=base

# Phase 3 — Integrations (optional)
# GITHUB_TOKEN=
# SLACK_BOT_TOKEN=
# GOOGLE_APPLICATION_CREDENTIALS=
